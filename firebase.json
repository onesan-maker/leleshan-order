{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": ".",
    "predeploy": ["node scripts/guard-deploy.mjs"],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "functions/**"
    ],
    "rewrites": [
      {
        "source": "pos-login",
        "destination": "/pos-login.html"
      },
      {
        "source": "pos-login/**",
        "destination": "/pos-login.html"
      },
      {
        "source": "pos-admin",
        "destination": "/pos-admin.html"
      },
      {
        "source": "pos-admin/**",
        "destination": "/pos-admin.html"
      },
      {
        "source": "pos",
        "destination": "/pos.html"
      },
      {
        "source": "pos/**",
        "destination": "/pos.html"
      },
      {
        "source": "kds",
        "destination": "/kds.html"
      },
      {
        "source": "kds/**",
        "destination": "/kds.html"
      },
      {
        "source": "packing",
        "destination": "/packing.html"
      },
      {
        "source": "packing/**",
        "destination": "/packing.html"
      },
      {
        "source": "pickup-board",
        "destination": "/pickup-board.html"
      },
      {
        "source": "pickup-board/**",
        "destination": "/pickup-board.html"
      },
      {
        "source": "line-bind",
        "destination": "/line-bind.html"
      },
      {
        "source": "line-bind/**",
        "destination": "/line-bind.html"
      },
      {
        "source": "admin-orders",
        "destination": "/admin-orders.html"
      },
      {
        "source": "admin-orders/**",
        "destination": "/admin-orders.html"
      },
      {
        "source": "admin/login",
        "destination": "/admin-login.html"
      },
      {
        "source": "admin/login/**",
        "destination": "/admin-login.html"
      },
      {
        "source": "admin",
        "destination": "/admin.html"
      },
      {
        "source": "admin/**",
        "destination": "/admin.html"
      },
      {
        "source": "pos-v2",
        "destination": "/pos-v2/index.html"
      },
      {
        "source": "pos-v2/**",
        "destination": "/pos-v2/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
